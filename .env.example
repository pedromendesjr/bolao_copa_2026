# Credenciais do Supabase
# 1. Crie um projeto em https://supabase.com
# 2. Vá em Project Settings > API
# 3. Copie a "Project URL" para SUPABASE_URL
# 4. Copie a "anon public" key para SUPABASE_KEY
#    (para o seed inicial você também pode usar a service_role key)

SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Fuso horário usado para deadlines de palpites
TIMEZONE=America/Sao_Paulo

# PIN do administrador (você) para acessar a tela de admin.
# Escolha algo difícil de adivinhar - só você deve saber.
ADMIN_PIN=troque-este-valor

# Telefone do administrador (você). Quando logar com este telefone,
# o menu "Admin" aparece na sidebar. 11 dígitos no formato DD9XXXXXXXX.
ADMIN_TELEFONE=47999998888
